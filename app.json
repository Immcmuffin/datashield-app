{
  "expo": {
    "name": "DataShield",
    "slug": "datashield-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "scheme": "datashield",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.removemydata.datashield",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "package": "app.removemydata.datashield",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#0f1117"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
